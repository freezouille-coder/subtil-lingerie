---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { boutique, marques } from '../data/boutique';
const phares = ['aubade', 'simone-perele', 'chantelle', 'wacoal', 'triumph', 'sloggi'];
const marquesPhares = marques.filter(m => phares.includes(m.slug));
---
<Base
  title="Subtil Lingerie — Bagnols-sur-Cèze"
  description="Boutique de lingerie au cœur de Bagnols-sur-Cèze. Aubade, Simone Pérèle, Chantelle, Wacoal, Triumph, Sloggi, Freya. Conseil personnalisé, essayage, marques de référence."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="/images/vitrine.jpg"
        alt="Façade de la boutique Subtil Lingerie au cœur de Bagnols-sur-Cèze"
        width="1920"
        height="1280"
        fetchpriority="high"
      />
    </div>
    <div class="hero-content container">
      <span class="eyebrow">Bagnols-sur-Cèze · centre-ville historique</span>
      <h1>
        L'art de se sentir bien,
        <em>au plus près de soi</em>
      </h1>
      <p class="lead">
        Une sélection rigoureuse des grandes maisons françaises et internationales —
        Aubade, Simone Pérèle, Chantelle, Wacoal, Triumph, Sloggi, Freya.
        <br/>Le conseil et l'essayage qui changent tout.
      </p>
      <div class="hero-cta">
        <a href="/marques" class="btn btn-primary">Découvrir nos marques</a>
        <a href="/contact" class="btn btn-ghost-light">Nous rendre visite</a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span>Découvrir</span>
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- VALEURS -->
  <section class="values bg-ivory">
    <div class="container">
      <div class="grid grid-3">
        <div class="value-card">
          <div class="value-icon">✦</div>
          <h3>Conseil personnalisé</h3>
          <p>L'œil expert d'une équipe passionnée. La bonne taille, la bonne matière, la pièce qui vous va vraiment.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">✦</div>
          <h3>Marques d'exception</h3>
          <p>Aubade, Simone Pérèle, Chantelle, Wacoal, Triumph… Les références françaises et internationales.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">✦</div>
          <h3>Discrétion & élégance</h3>
          <p>Une boutique de centre-ville où l'on se sent immédiatement à l'aise, pour soi ou pour offrir.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOUTIQUE PREVIEW -->
  <section class="boutique-preview">
    <div class="container preview-grid">
      <div class="preview-text">
        <span class="eyebrow">Notre maison</span>
        <h2>Une boutique de cœur, en plein centre-ville</h2>
        <p>
          Subtil Lingerie, c'est un savoir-faire familial au service de toutes les femmes :
          des essentiels du quotidien aux pièces d'exception, des bonnets profonds aux silhouettes
          plus fines, des nuits douces aux maillots d'été. Chaque cliente repart avec ce qu'elle est
          venue chercher — souvent un peu plus.
        </p>
        <p>
          Vous pouvez nous trouver au <strong>{boutique.adresse.rue}</strong>, à
          <strong> {boutique.adresse.ville}</strong>.
        </p>
        <a href="/boutique" class="btn btn-ghost">En savoir plus</a>
      </div>
      <div class="preview-image">
        <img
          src="/images/vitrine.jpg"
          alt="Façade de la boutique Subtil Lingerie à Bagnols-sur-Cèze"
          width="1600"
          height="1200"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- VIDÉO TOUR BOUTIQUE -->
  <section class="video-tour bg-ivory">
    <div class="container">
      <div class="section-head text-center">
        <span class="eyebrow">Visite virtuelle</span>
        <h2>Bienvenue chez Subtil</h2>
        <div class="divider">✦</div>
        <p class="lead" style="max-width: 560px; margin: 0 auto;">
          Une boutique pensée pour le conseil et l'essayage : marques exposées, pièces tactiles,
          ambiance soignée.
        </p>
      </div>
      <div class="video-frame">
        <video
          src="/video/boutique-tour.mp4"
          poster="/images/boutique-tour-poster.jpg"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="Visite vidéo de la boutique Subtil Lingerie"
        ></video>
      </div>
    </div>
  </section>

  <!-- ÉDITORIAL FEATURE -->
  <section class="editorial-feature">
    <div class="container">
      <div class="editorial-grid">
        <div class="editorial-image">
          <img src="/images/boutique-interior.jpg" alt="Détail d'une parure de lingerie en dentelle aubergine sur table de marbre" loading="lazy" />
        </div>
        <div class="editorial-text">
          <span class="eyebrow">L'art de la pièce parfaite</span>
          <h2>Chaque essai est un petit rituel</h2>
          <p>
            Une dentelle bien coupée, un satin qui tombe juste, une bretelle qui ne marque pas.
            Ce sont des détails minuscules — et ce sont eux qui font qu'on porte une pièce
            tous les jours plutôt qu'une fois par an.
          </p>
          <a href="/marques" class="link-quiet">Découvrir nos sélections →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TROIS UNIVERS -->
  <section class="universes">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Trois univers</span>
        <h2>De jour, de nuit, d'été</h2>
        <div class="divider">✦</div>
      </div>
      <div class="universe-grid">
        <a href="/marques" class="universe-card">
          <div class="universe-image"><img src="/images/mood-aubade.jpg" alt="Lingerie en dentelle aubergine" loading="lazy" /></div>
          <div class="universe-text">
            <h3>Lingerie de jour</h3>
            <p>Des essentiels du quotidien aux pièces d'exception, dentelles brodées et coupes parfaites.</p>
          </div>
        </a>
        <a href="/marques#tress" class="universe-card">
          <div class="universe-image"><img src="/images/mood-nuit.jpg" alt="Chemise de nuit en soie ivoire sur draps de lin" loading="lazy" /></div>
          <div class="universe-text">
            <h3>Lingerie de nuit</h3>
            <p>Soie, satin, coton lavé. Le rituel du soir, la douceur du sommeil.</p>
          </div>
        </a>
        <a href="/marques#maillots" class="universe-card">
          <div class="universe-image"><img src="/images/mood-maillots.jpg" alt="Maillot de bain terracotta sur chaise en rotin au bord de la piscine" loading="lazy" /></div>
          <div class="universe-text">
            <h3>Maillots de bain</h3>
            <p>Une sélection estivale renouvelée chaque saison, pour la plage et la piscine.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- MARQUES PHARES -->
  <section class="brands bg-ivory">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Nos marques</span>
        <h2>Une sélection rigoureuse</h2>
        <div class="divider">✦</div>
      </div>
      <div class="brand-grid">
        {marquesPhares.map(m => (
          <a href={`/marques#${m.slug}`} class="brand-card" style={`--accent: ${m.accent}`}>
            <span class="brand-name">{m.nom}</span>
            <span class="brand-pitch">{m.pitch}</span>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top: 2.5rem;">
        <a href="/marques" class="link-quiet">Voir toutes nos marques →</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <Newsletter variant="section" />

  <!-- CONTACT QUICK -->
  <section class="bg-aubergine cta">
    <div class="container-narrow text-center">
      <span class="eyebrow">Venez nous voir</span>
      <h2>Rien ne remplace l'essayage</h2>
      <p class="lead">
        {boutique.adresse.rue} · {boutique.adresse.cp} {boutique.adresse.ville}<br/>
        <a class="phone-cta" href={`tel:${boutique.telephoneTel}`}>{boutique.telephoneAffiche}</a>
      </p>
      <a href="/contact" class="btn btn-ghost-light cta-btn">Horaires & accès</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 88vh, 820px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
    color: var(--c-cream);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-bg img { animation: heroPan 30s ease-out both; }
    .hero-scroll .scroll-line { animation: scrollHint 2s ease-in-out infinite; }
  }
  @keyframes heroPan {
    from { transform: scale(1.08); }
    to   { transform: scale(1.0); }
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(42, 31, 38, 0.15) 0%, rgba(42, 31, 38, 0.55) 60%, rgba(42, 31, 38, 0.85) 100%),
      linear-gradient(90deg, rgba(42, 31, 38, 0.45) 0%, transparent 50%);
  }
  .hero-content {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(4rem, 9vw, 7rem);
    max-width: 720px;
  }
  .hero-content .eyebrow {
    color: var(--c-gold-light);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
  }
  .hero-content h1 {
    color: var(--c-cream);
    line-height: 1.1;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.4);
    font-weight: 400;
  }
  .hero-content h1 em {
    display: block;
    font-style: italic;
    color: var(--c-gold-light);
    font-family: var(--font-script);
    font-size: 1.5em;
    line-height: 0.95;
    margin-top: 0.4rem;
    font-weight: 400;
  }
  .hero-content .lead {
    color: var(--c-cream);
    margin-top: 1.75rem;
    max-width: 560px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    font-size: 1.1rem;
    line-height: 1.55;
    opacity: 0.95;
  }
  .hero-cta { display: flex; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    right: clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--c-gold-light);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .hero-scroll .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--c-gold-light), transparent);
  }
  @keyframes scrollHint {
    0%, 100% { transform: scaleY(1); transform-origin: top; opacity: 0.6; }
    50% { transform: scaleY(1.4); opacity: 1; }
  }

  @media (max-width: 720px) {
    .hero-scroll { display: none; }
    .hero-content h1 em { font-size: 1.3em; }
  }

  /* Lien téléphone dans la CTA aubergine */
  .phone-cta {
    color: var(--c-gold-light);
    border-bottom: 1px solid var(--c-gold-light);
    padding-bottom: 1px;
  }
  .phone-cta:hover { color: var(--c-cream); border-color: var(--c-cream); }

  .value-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .value-icon {
    font-size: 1.5rem;
    color: var(--c-gold);
    margin-bottom: 1rem;
  }
  .value-card h3 { margin-bottom: 0.75rem; color: var(--c-aubergine); }
  .value-card p { color: var(--c-muted); }

  .preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .preview-text h2 { margin-bottom: 1.5rem; }
  .preview-text p { margin-bottom: 1rem; color: var(--c-ink); }
  .preview-text .btn { margin-top: 1rem; }

  .preview-image {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 3px;
    box-shadow: 0 20px 40px -20px rgba(107, 62, 94, 0.3);
  }
  .preview-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .editorial-feature {
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
    background: var(--c-cream);
  }
  .editorial-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1100px;
    margin-inline: auto;
  }
  .editorial-image {
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 3px;
    box-shadow: 0 24px 48px -24px rgba(74, 42, 65, 0.4);
  }
  .editorial-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .editorial-text h2 { margin-bottom: 1.25rem; }
  .editorial-text p { margin-bottom: 1.5rem; color: var(--c-ink); font-size: 1.05rem; line-height: 1.7; }
  @media (max-width: 760px) {
    .editorial-grid { grid-template-columns: 1fr; gap: 2rem; }
    .editorial-image { aspect-ratio: 4/3; max-width: 480px; margin-inline: auto; }
  }

  .video-tour { padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .video-tour .lead { margin-top: 1rem; color: var(--c-muted); }
  .video-frame {
    margin-top: 3rem;
    max-width: 480px;
    margin-inline: auto;
    aspect-ratio: 9/16;
    border-radius: 6px;
    overflow: hidden;
    background: var(--c-aubergine-dark);
    box-shadow: 0 30px 60px -25px rgba(74, 42, 65, 0.5);
    position: relative;
  }
  .video-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 760px) {
    .video-frame { max-width: 380px; }
  }

  .universes { padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .universe-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .universe-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s var(--ease);
  }
  .universe-card:hover { transform: translateY(-4px); }
  .universe-image {
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 3px;
    box-shadow: 0 16px 32px -16px rgba(74, 42, 65, 0.35);
    margin-bottom: 1.25rem;
  }
  .universe-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .universe-card:hover .universe-image img { transform: scale(1.04); }
  .universe-text h3 { color: var(--c-aubergine-dark); margin-bottom: 0.5rem; font-size: 1.4rem; }
  .universe-text p { color: var(--c-muted); font-size: 0.95rem; line-height: 1.6; }
  @media (max-width: 860px) {
    .universe-grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
  }

  .section-head { text-align: center; margin-bottom: 3rem; }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0;
    border-top: 1px solid var(--c-line);
    border-left: 1px solid var(--c-line);
  }
  .brand-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2.25rem 1.75rem;
    background: transparent;
    border-right: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
    text-align: left;
    transition: background 0.3s var(--ease);
    text-decoration: none;
    position: relative;
  }
  .brand-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease);
  }
  .brand-card:hover {
    background: var(--c-cream);
  }
  .brand-card:hover::before { transform: scaleX(1); }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.65rem;
    color: var(--c-aubergine-dark);
    letter-spacing: -0.005em;
    transition: color 0.25s var(--ease);
  }
  .brand-card:hover .brand-name { color: var(--accent); }
  .brand-pitch {
    font-size: 0.9rem;
    color: var(--c-muted);
    line-height: 1.55;
  }

  .text-center { text-align: center; }

  @media (max-width: 860px) {
    .preview-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
