---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { marques } from '../data/boutique';
---
<Base
  title="Nos marques — Subtil Lingerie · Bagnols-sur-Cèze"
  description="Aubade, Simone Pérèle, Chantelle, Wacoal, Triumph, Sloggi, Freya, Tress, Sara, Maillots de bain. Découvrez nos maisons partenaires."
>
  <section class="page-hero">
    <div class="page-hero-bg">
      <img src="/images/mood-aubade.jpg" alt="" aria-hidden="true" />
    </div>
    <div class="container-narrow text-center page-hero-content">
      <span class="eyebrow">Nos partenaires</span>
      <h1>Les maisons que <em>nous aimons</em></h1>
      <p class="lead">
        Une sélection française et internationale, choisie pour la qualité, l'ajustement
        et la diversité des morphologies couvertes.
      </p>
    </div>
  </section>

  <section class="display-feature">
    <div class="container">
      <figure class="display-figure">
        <img
          src="/images/marques-editorial.jpg"
          alt="Portant en boutique avec une variété de soutiens-gorge : dentelle, balconnet, triangle, push-up, sport — tons crème, terracotta, burgundy, noir"
          loading="lazy"
          width="2752"
          height="1536"
        />
        <figcaption>
          <span class="eyebrow">Toutes les morphologies, accueillies</span>
          <p>Du 85A au 105G, du triangle au balconnet, de la pièce du quotidien au modèle d'exception. On a la coupe qui vous va.</p>
        </figcaption>
      </figure>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="brand-list">
        {marques.map((m, i) => (
          <article id={m.slug} class="brand-row" style={`--accent: ${m.accent}`}>
            <div class="brand-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="brand-body">
              <h2>{m.nom}</h2>
              <p class="brand-pitch-line">{m.pitch}</p>
              <p>{m.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-aubergine cta">
    <div class="container-narrow text-center">
      <span class="eyebrow">Vous cherchez une référence précise ?</span>
      <h2>Appelez-nous, on vérifie le stock</h2>
      <p class="lead">
        Plutôt que de commander en aveugle, dites-nous ce que vous cherchez —
        modèle, taille, couleur — et on vous dit immédiatement si c'est en boutique.
      </p>
      <a href="/contact" class="btn btn-ghost-light cta-btn">Nous contacter</a>
    </div>
  </section>

  <Newsletter variant="section" />
</Base>

<style>
  .display-feature {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(1rem, 3vw, 2rem);
  }
  .display-figure {
    max-width: 1100px;
    margin-inline: auto;
    text-align: center;
  }
  .display-figure img {
    width: 100%;
    height: auto;
    border-radius: 3px;
    box-shadow: 0 30px 60px -28px rgba(74, 42, 65, 0.4);
    margin-bottom: 1.75rem;
  }
  .display-figure figcaption {
    max-width: 600px;
    margin-inline: auto;
  }
  .display-figure figcaption p {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-style: italic;
    color: var(--c-aubergine);
    line-height: 1.45;
    margin-top: 0.5rem;
  }

  .brand-list {
    display: flex;
    flex-direction: column;
    max-width: 880px;
    margin-inline: auto;
  }
  .brand-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--c-line);
    align-items: start;
  }
  .brand-row:last-child { border-bottom: 1px solid var(--c-line); }
  .brand-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--accent);
    font-weight: 500;
    line-height: 1;
  }
  .brand-body h2 {
    margin-bottom: 0.5rem;
    color: var(--accent);
  }
  .brand-pitch-line {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--c-aubergine);
    margin-bottom: 1rem;
  }
  .brand-body p { margin-bottom: 0.75rem; }

  @media (max-width: 600px) {
    .brand-row { grid-template-columns: 1fr; gap: 0.5rem; padding: 2rem 0; }
    .brand-num { font-size: 1.5rem; }
  }
</style>
