---
interface Props {
  variant?: 'inline' | 'section';
}
const { variant = 'section' } = Astro.props;
---
<div class:list={['newsletter', variant]}>
  <div class:list={[variant === 'section' ? 'container-narrow' : '', 'newsletter-inner']}>
    {variant === 'section' && (
      <>
        <span class="eyebrow">Restons en contact</span>
        <h2>Les nouveautés, en avant-première</h2>
        <p class="lead">
          Recevez nos arrivages, nos sélections de saison et nos invitations privées —
          maximum un email par mois, jamais de spam.
        </p>
      </>
    )}

    <form
      class="newsletter-form"
      action="https://sibforms.com/serve/MUIFAJUR_PLACEHOLDER"
      method="POST"
      novalidate
      data-newsletter
    >
      <label class="visually-hidden" for="nl-email">Votre adresse email</label>
      <input
        id="nl-email"
        type="email"
        name="EMAIL"
        placeholder="votre@email.fr"
        required
        autocomplete="email"
      />
      <button type="submit" class="btn btn-primary">S'inscrire</button>

      <p class="rgpd">
        En vous inscrivant, vous acceptez de recevoir nos communications.
        Vous pouvez vous désinscrire à tout moment via le lien en bas de chaque email.
      </p>

      <div class="form-message" role="status" aria-live="polite"></div>
    </form>
  </div>
</div>

<style>
  .newsletter.section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    background: var(--c-mauve-light);
    text-align: center;
  }
  .newsletter.section .lead { margin: 1rem auto 2rem; max-width: 560px; }

  .newsletter-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    max-width: 560px;
    margin-inline: auto;
  }
  .newsletter-form input {
    padding: 0.95rem 1.25rem;
    font-size: 1rem;
    font-family: var(--font-body);
    background: var(--c-cream);
    border: 1px solid var(--c-line);
    border-radius: 2px;
    color: var(--c-ink);
    transition: border-color 0.2s var(--ease);
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--c-aubergine);
  }
  .rgpd {
    grid-column: 1 / -1;
    font-size: 0.78rem;
    color: var(--c-muted);
    margin-top: 0.5rem;
    text-align: center;
    line-height: 1.5;
  }
  .form-message {
    grid-column: 1 / -1;
    min-height: 1.5rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }
  .form-message.success { color: #2c7a4f; }
  .form-message.error   { color: #b04545; }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  @media (max-width: 540px) {
    .newsletter-form { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Brevo n'étant pas encore configuré, on intercepte la soumission
  // pour afficher un message de confirmation factice et éviter une 404.
  // Quand l'identifiant Brevo réel sera mis dans `action="..."`, retirer ce script.
  document.querySelectorAll<HTMLFormElement>('form[data-newsletter]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const action = form.getAttribute('action') || '';
      if (action.includes('PLACEHOLDER')) {
        e.preventDefault();
        const msg = form.querySelector('.form-message');
        const input = form.querySelector('input[type="email"]') as HTMLInputElement;
        if (msg && input) {
          if (!input.value || !input.checkValidity()) {
            msg.textContent = "Adresse email invalide.";
            msg.className = 'form-message error';
            return;
          }
          msg.textContent = `Merci ! ${input.value} sera bien ajouté à notre newsletter dès la mise en ligne (formulaire en cours d'intégration).`;
          msg.className = 'form-message success';
          input.value = '';
        }
      }
    });
  });
</script>
